% ---- Select text fonts ----

% Make PDF searchable and copyable
\input{glyphtounicode}
\pdfgentounicode=1

% Select font encoding 
\usepackage[T1]{fontenc}

% Select text font
\usepackage{sourceserifpro}

% Define semibold font series
\DeclareRobustCommand{\sbseries}{\fontseries{sb}\selectfont}
\DeclareTextFontCommand{\textsb}{\sbseries}

% Select monospaced font
\usepackage{sourcecodepro}

% ---- Select math fonts ----

% Select symbol font
\usepackage{MnSymbol}

% Select calligraphic and blackboard-bold fonts
\usepackage[cal=euler, bb=fourier]{mathalpha}

% Select font for Roman letters, Greek letters, digits, and punctuation
\usepackage[italic, eulergreek, nolessnomore, noparenthesis, noplusnominus, noequal, nohbar]{mathastext}

% Correct spacing around certain Roman letters
\MTsetmathskips{f}{3mu}{0mu}
\MTsetmathskips{y}{2mu}{0mu}
\MTsetmathskips{p}{2mu}{0mu}
\MTsetmathskips{j}{2mu}{0mu}

% ---- Adjust page layout ----

\usepackage[top=0.9in, left=1.2in, right=1.2in, bottom=1.1in, footskip=0.7in]{geometry}

% ---- Adjust spacing ----

% Customize spacing between lines
\usepackage{setspace}

% Set spacing between lines
\setstretch{1.1}

% Adjust spacing on lines
\usepackage{microtype}

% Adjust spacing in text
\AtBeginDocument{\frenchspacing}

% ---- Select color scheme ----

\usepackage[x11names]{xcolor}

% ---- Format header and footer ----

% Customize headers and footers
\usepackage{fancyhdr}

% Activate custom header and footer
\pagestyle{fancy}

% Eliminate header line
\renewcommand{\headrulewidth}{0pt}

% Clear header and footer
\fancyhf{}

% ---- Format section headings ----

% Customize section headings
\usepackage{titlesec}

% Format section headings
\titleformat*{\section}{\centering\Huge\scshape}

% Format subsection headings
\titleformat*{\subsection}{\vskip-3mm\sbseries\scshape\color{gray}}

% ---- Format lists ----

% Customize lists
\usepackage{enumitem}

% Format itemized lists
\setlist[itemize, 1]{leftmargin=2em, label=\color{gray}{\textendash}}

% Format forward-numbered lists
\setlist[enumerate, 1]{leftmargin=2em}

% Format backward-numbered lists
\usepackage[leftmargin=2em]{etaremune}

% Format items for numbered lists
\renewcommand{\labelenumi}{\color{gray}\theenumi.}

% ---- Enable hyperlinks  ----

\PassOptionsToPackage{hyphens}{url}
\usepackage[hidelinks, hypertexnames=false, pdfpagemode=UseNone, pdfdisplaydoctitle=true]{hyperref}

% ---- Define CV commands ----

% Command for CV title
\newcommand*{\name}[1]{\section*{#1}}

% Command for inline separator
\newcommand{\sep}{{\color{gray}\,\textbullet\,\,}}

% Command for block separator
\newcommand{\hsep}{\noindent\textcolor{gray}{\rule{\textwidth}{0.7pt}}}

% Command for block heading
\newcommand*{\block}[1]{\begin{samepage}\hsep\subsection*{{#1}}\end{samepage}}

% Command for coauthor entry
\newcommand*{\with}[1]{\,(with #1)}

% Command for gray footer
\newcommand*{\grayfoot}[2]{\fancyfoot[#1]{\footnotesize\textcolor{gray}{#2}}}